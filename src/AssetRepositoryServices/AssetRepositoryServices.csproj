<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <ApplicationIcon />
        <AssemblyName>Meshmakers.Octo.Backend.AssetRepositoryServices</AssemblyName>
        <Description>Asset Repository Service of Octo Mesh, provides access to data products.</Description>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
        <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
        <IsPackable>false</IsPackable>
        <OutputType>Exe</OutputType>
        <RootNamespace>Meshmakers.Octo.Backend.AssetRepositoryServices</RootNamespace>
        <StartupObject />
        <UserSecretsId>173d8e91-b831-4e8a-a43f-672c57e6a4da</UserSecretsId>
        <Configurations>Debug;Release;DebugL</Configurations>
        <Platforms>AnyCPU</Platforms>
        <OutputPath>..\..\bin\$(Configuration)\</OutputPath>
        <DocumentationFile>..\..\bin\$(Configuration)\$(AssemblyName).xml</DocumentationFile>
        <NoWarn>1701;1702;CS8002</NoWarn>
        <CopyDocumentationFilesFromPackages>true</CopyDocumentationFilesFromPackages>
    </PropertyGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="Meshmakers.Octo.Backend.AssetRepositoryServices.IntegrationTests" />
        <InternalsVisibleTo Include="AssetRepositoryServices.UnitTests" />
        <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="GraphQL.DataLoader" Version="8.8.4" />
        <PackageReference Include="GraphQL.MicrosoftDI" Version="8.8.4" />
        <PackageReference Include="GraphQL.Server.Transports.AspNetCore" Version="8.3.3" />
        <PackageReference Include="GraphQL.Server.Ui.Altair" Version="8.3.3" />
        <PackageReference Include="GraphQL.SystemTextJson" Version="8.8.4" />
        <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.7" />
        <PackageReference Include="Microsoft.AspNetCore.Authentication.OpenIdConnect" Version="10.0.7" />
        <PackageReference Include="NLog.Web.AspNetCore" Version="6.1.3" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Meshmakers.Octo.Services.Infrastructure" Version="$(OctoVersion)" />
        <PackageReference Include="Meshmakers.Octo.Services.Observability" Version="$(OctoVersion)" />
        <PackageReference Include="Meshmakers.Octo.Services.Swagger" Version="$(OctoVersion)" />
        <PackageReference Include="Meshmakers.Octo.Runtime.Engine.MongoDb" Version="$(OctoVersion)" />
        <ProjectReference Include="..\..\tests\AssetRepositoryIntegrationTestCkModel\AssetRepositoryIntegrationTestCkModel.csproj" />
        <ProjectReference Include="..\AssetRepositoryServices.Resources\AssetRepositoryServices.Resources.csproj" />
    </ItemGroup>

    <ItemGroup>
        <Content Update="wwwroot\css\swagger.css">
            <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
            <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
      <Content Remove="GraphQL\RequestHandling\playground.cshtml" />
      <EmbeddedResource Include="GraphQL\RequestHandling\playground.cshtml" />
    </ItemGroup>

</Project>